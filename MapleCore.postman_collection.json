{
  "info": {
    "_postman_id": "7f8b9c1d-1029-4c8d-bf84-884c988a8342",
    "name": "MapleCore Banking Platform",
    "description": "Comprehensive REST APIs collection for the secure core banking services of modern Canadian financial sandbox installations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Customer Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newcustomer@maplecore.ca\",\n  \"password\": \"password123\",\n  \"firstName\": \"Robert\",\n  \"lastName\": \"Borden\",\n  \"phoneNumber\": \"+1 (613) 555-0144\",\n  \"dateOfBirth\": \"1980-05-20\",\n  \"address\": {\n    \"streetAddress\": \"24 Sussex Dr\",\n    \"city\": \"Ottawa\",\n    \"province\": \"ON\",\n    \"postalCode\": \"K1M 1M4\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "customers",
                "register"
              ]
            }
          }
        },
        {
          "name": "Sign In User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "    pm.environment.set(\"accessToken\", jsonData.accessToken);",
                  "    pm.environment.set(\"refreshToken\", jsonData.refreshToken);",
                  "    pm.test(\"Token cached in environment successfully\", function () {",
                  "        pm.expect(pm.environment.get(\"accessToken\")).to.not.be.undefined;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@maplecore.ca\",\n  \"password\": \"customerpassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        {
          "name": "List Accounts",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Transactions & Ledgers",
      "item": [
        {
          "name": "Execute Transfer (Held if flagged)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Idempotency-Key",
                "value": "c8888888-8888-8888-8888-888888888888"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceAccountNumber\": \"1004382910\",\n  \"destinationAccountNumber\": \"2008471920\",\n  \"amount\": 150.00,\n  \"description\": \"e-transfer split bill\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions/transfers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions",
                "transfers"
              ]
            }
          }
        }
      ]
    }
  ],
